class Person {
    public string $firstName;
    public string $lastName;

    public function sayHello(string $name): string {
        return "Hello $name, my name is {$this->firstName}.";
    }

    public function sayGoodBye(string $name): string {
        return "Good bye $name, see you later!";
    }
}

$eko = new Person();
$eko->firstName = "Eko";
$eko->lastName = "Eko";

